generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLINICIAN
  ADMIN
}

enum PatientSex {
  FEMALE
  MALE
  OTHER
  NOT_SPECIFIED
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  ON_HOLD
  CANCELLED
}

enum RehabPlanPhase {
  ACUTE
  SUBACUTE
  STRENGTHENING
  RETURN_TO_ACTIVITY
  MAINTENANCE
}

enum RehabPlanStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum ClinicalGoalStatus {
  ACTIVE
  ACHIEVED
  PAUSED
  CANCELLED
}

enum ClinicalGoalPriority {
  LOW
  MEDIUM
  HIGH
}

enum SessionStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum ClinicalDecision {
  MAINTAIN
  PROGRESS
  REGRESS
  REFER
}

enum MetricType {
  PAIN
  ROM
  STRENGTH
  FUNCTION
  ADHERENCE
  BALANCE
  OTHER
}

enum MetricUnit {
  NRS_0_10
  DEGREES
  KG
  REPETITIONS
  SECONDS
  PERCENT
  SCORE
}

enum BodyRegion {
  CERVICAL
  THORACIC
  LUMBAR
  SHOULDER
  ELBOW
  WRIST_HAND
  HIP
  KNEE
  ANKLE_FOOT
  GENERAL
  OTHER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole   @default(CLINICIAN)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  patients     Patient[]
  exercises    Exercise[]
}

model Patient {
  id                    String                 @id @default(cuid())
  userId                String
  firstName             String
  lastName              String
  documentNumber        String?
  dateOfBirth           DateTime?
  sex                   PatientSex            @default(NOT_SPECIFIED)
  phone                 String?
  email                 String?
  occupation            String?
  address               String?
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  initialAssessment     InitialAssessment?
  objectiveAssessments  ObjectiveAssessment[]
  rehabPlans            RehabPlan[]
  clinicalGoals         ClinicalGoal[]
  sessions              Session[]
  progressMetrics       ProgressMetric[]

  @@index([userId])
  @@index([lastName, firstName])
}

model InitialAssessment {
  id                    String   @id @default(cuid())
  patientId             String   @unique
  reasonForConsultation String
  onsetDate             DateTime?
  injuryMechanism       String?
  medicalDiagnosis      String?
  currentPain           Int?
  maxPain               Int?
  minPain               Int?
  painLocation          String?
  painType              String?
  irradiation           String?
  aggravatingFactors    String?
  relievingFactors      String?
  neurologicalSymptoms  String?
  previousSurgeries     String?
  medications           String?
  relevantHistory       String?
  redFlags              String?
  patientGoals          String?
  limitedActivities     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  patient               Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ObjectiveAssessment {
  id                 String     @id @default(cuid())
  patientId          String
  bodyRegion         BodyRegion
  postureObservation String?
  rangeOfMotion      String?
  strength           String?
  functionalTests    String?
  specialTests       String?
  palpationFindings  String?
  movementQuality    String?
  balance            String?
  gait               String?
  notes              String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  patient            Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([bodyRegion])
}

model RehabPlan {
  id               String          @id @default(cuid())
  patientId        String
  title            String
  description      String?
  phase            RehabPlanPhase
  frequencyPerWeek Int?
  status           RehabPlanStatus @default(ACTIVE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([phase])
}

model ClinicalGoal {
  id          String               @id @default(cuid())
  patientId   String
  description String
  targetDate  DateTime?
  status      ClinicalGoalStatus   @default(ACTIVE)
  priority    ClinicalGoalPriority @default(MEDIUM)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([priority])
}

model Exercise {
  id               String            @id @default(cuid())
  userId           String
  name             String
  description      String?
  bodyRegion       BodyRegion?
  objective        String?
  defaultSets      Int?
  defaultReps      Int?
  defaultDuration  Int?
  defaultLoad      String?
  precautions      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionExercises SessionExercise[]

  @@index([userId])
  @@index([name])
  @@index([bodyRegion])
}

model Session {
  id                  String            @id @default(cuid())
  patientId           String
  date                DateTime
  painBefore          Int?
  painAfter           Int?
  subjectiveReport    String?
  clinicalNotes       String?
  responseToTreatment String?
  clinicalDecision    ClinicalDecision?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  patient             Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessionExercises    SessionExercise[]
  progressMetrics     ProgressMetric[]

  @@index([patientId, date])
  @@index([clinicalDecision])
}

model SessionExercise {
  id         String   @id @default(cuid())
  sessionId  String
  exerciseId String
  sets       Int?
  reps       Int?
  duration   Int?
  load       String?
  rpe        Int?
  symptoms   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([exerciseId])
}

model ProgressMetric {
  id         String     @id @default(cuid())
  patientId  String
  sessionId  String?
  metricType MetricType
  name       String
  value      Decimal    @db.Decimal(10, 2)
  unit       MetricUnit
  date       DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  session    Session?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([patientId, metricType, date])
  @@index([sessionId])
}
