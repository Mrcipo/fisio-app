PORT=4000
DATABASE_URL=postgresql://fisioterapia_user:fisioterapia_pass@localhost:5432/fisioterapia_db?schema=public
JWT_SECRET=change_me
ALLOWED_ORIGIN=http://localhost:3000
# "production" activa la flag `secure: true` en la cookie JWT, lo que exige HTTPS.
# En desarrollo local usar "development" para permitir HTTP.
NODE_ENV=development
# Path al ejecutable de Chrome/Chromium para generación de PDF.
# Linux:   /usr/bin/google-chrome
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=
